  "query": "SELECT\n    id          AS \"id!\",\n    space_id    AS \"space_id!\",\n    table_name  AS \"table_name!\",\n    row_id      AS \"row_id!\",\n    operation   AS \"operation!\",\n    payload     AS \"payload\",\n    seq         AS \"seq!: i64\",\n    device_id   AS \"device_id!\",\n    changed_at  AS \"changed_at!\"\nFROM change_log\nWHERE space_id = ?1\n  AND device_id = ?2\n  AND seq > ?3\nORDER BY seq ASC\nLIMIT ?4\n",
