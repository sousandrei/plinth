  "query": "SELECT\n    space_id  AS \"space_id!\",\n    device_id AS \"device_id!\",\n    cert_pem  AS \"cert_pem!\"\nFROM trusted_devices td\nINNER JOIN spaces s ON s.id = td.space_id\nUNION\nSELECT\n    space_id  AS \"space_id!\",\n    device_id AS \"device_id!\",\n    cert_pem  AS \"cert_pem!\"\nFROM evicted_devices ed\nINNER JOIN spaces s ON s.id = ed.space_id\n",
