{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plinth",
  "version": "1.5.0",
  "identifier": "plinth",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plinth",
        "width": 1200,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "parsers": "parsers"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4NEQ0QkFDQzZCNjdEQ0YKUldUUGZiYkdyRXROU1B6YXBlaUNZZzFaUEtMNVczayt0eTF0R2tyMGIxeVNoYTF6OTVDSC9HNzgK",
      "endpoints": [
        "https://github.com/sousandrei/plinth/releases/latest/download/latest.json"
      ]
    }
  }
}