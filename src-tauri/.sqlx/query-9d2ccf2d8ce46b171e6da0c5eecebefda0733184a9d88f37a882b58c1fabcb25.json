  "query": "SELECT t.id, t.text, t.amount, t.booking_date, t.category AS \"category!\"\nFROM transactions t\nJOIN accounts a ON t.account_id = a.id\nWHERE a.user_id = ?1\n  AND t.approved = 1\n  AND t.category IS NOT NULL\n  AND t.category != ''\nORDER BY RANDOM()\nLIMIT ?2\n",
